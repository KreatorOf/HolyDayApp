    "notification.question.1" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What would you like to bring to God today?"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Qu'as-tu envie de confier à Dieu aujourd'hui ?"
          }
