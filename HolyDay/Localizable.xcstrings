    "legal.section.data.content" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "HolyDay does not collect any personally identifiable data. Your prayers and prayer journal remain on your device and are never transmitted to third-party servers."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "HolyDay ne collecte aucune donnée personnelle identifiable. Vos prières et votre journal de prière restent sur votre appareil et ne sont jamais transmis à des serveurs tiers."
          }
        }
      }
    },
    "legal.section.ip" : {
