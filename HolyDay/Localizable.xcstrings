    "home.meditate.1" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Where have you felt God's presence recently?"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
