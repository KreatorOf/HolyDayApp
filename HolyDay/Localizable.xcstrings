    "notification.question.0" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What can you give thanks for today?"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pour quoi peux-tu rendre grâce aujourd'hui ?"
          }
