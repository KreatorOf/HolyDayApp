    "legal.section.roadmap.content" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If you use the roadmap voting feature, an anonymous device identifier (randomly generated UUID) is sent to our servers to count your vote and prevent duplicates. This identifier cannot identify you personally and is not associated with any other data about you."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si vous utilisez la fonctionnalité de vote pour la roadmap, un identifiant anonyme propre à votre appareil (UUID généré aléatoirement) est transmis à nos serveurs pour comptabiliser votre vote et prévenir les doublons. Cet identifiant ne permet pas de vous identifier personnellement et n'est associé à aucune autre donnée vous concernant."
          }
        }
      }
    },
