      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "How is your heart today?"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Comment ton cœur se porte-t-il aujourd'hui ?"
          }
