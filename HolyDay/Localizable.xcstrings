      }
    },
    "legal.section.data.content" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "HolyDay does not collect any personally identifiable data. Your prayers and prayer journal remain on your device and are never transmitted to third-party servers."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "HolyDay ne collecte aucune donnée personnelle identifiable. Vos prières et votre journal de prière restent sur votre appareil et ne sont jamais transmis à des serveurs tiers."
          }
        }
      }
    },
    "legal.section.ip" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Intellectual property"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Propriété intellectuelle"
          }
        }
      }
    },
    "legal.section.ip.content" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The interface, icons and source code of HolyDay are protected by copyright. Any reproduction without permission is prohibited."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'interface, les icônes et le code source de HolyDay sont protégés par le droit d'auteur. Toute reproduction sans autorisation est interdite."
          }
        }
      }
    },
