      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If you enable prayer reminders, the app uses iOS local notifications. No data is sent outside your device in this context."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si vous activez les rappels de prière, l'application utilise les notifications locales d'iOS. Aucune donnée n'est envoyée hors de votre appareil dans ce cadre."
          }
        }
      }
    },
